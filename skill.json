{
  "name": "subtitle-generator",
  "displayName": "字幕生成器 / 字幕打轴",
  "description": "基于音频和口播稿进行字幕打轴，生成带时间戳的 SRT 字幕文件。支持上传音频文件和口播稿文件（或文本），灵活选择返回格式：JSON内容、文件下载或保存到指定路径。",
  "version": "1.0.0",
  "author": "onebigmoon",
  "license": "MIT",
  "type": "api",
  "entry": {
    "type": "http",
    "url": "http://localhost:8000",
    "endpoints": {
      "generate": {
        "path": "/generate",
        "method": "POST",
        "contentType": "multipart/form-data"
      },
      "models": {
        "path": "/models",
        "method": "GET"
      },
      "health": {
        "path": "/health",
        "method": "GET"
      }
    }
  },
  "parameters": {
    "audio": {
      "type": "file",
      "description": "音频文件 (MP3/WAV/M4A/FLAC/OGG/AAC等)",
      "required": true
    },
    "script": {
      "type": "string",
      "description": "口播稿文本内容（与 script_file 二选一）",
      "required": false
    },
    "script_file": {
      "type": "file",
      "description": "口播稿文件 .txt（与 script 二选一）",
      "required": false
    },
    "model": {
      "type": "enum",
      "description": "Whisper 模型大小",
      "options": ["tiny", "base", "small", "medium", "large"],
      "default": "base",
      "required": false
    },
    "output_format": {
      "type": "enum",
      "description": "返回格式：json返回JSON内容，file直接下载文件，path保存到指定路径",
      "options": ["json", "file", "path"],
      "default": "json",
      "required": false
    },
    "output_path": {
      "type": "string",
      "description": "当 output_format=path 时，指定输出文件路径（如 /app/output/subtitle.srt）",
      "required": false
    }
  },
  "inputs": ["audio", "script/script_file"],
  "outputs": {
    "success": {
      "type": "boolean",
      "description": "是否成功"
    },
    "message": {
      "type": "string",
      "description": "结果消息"
    },
    "srt_content": {
      "type": "string",
      "description": "SRT 字幕内容（output_format=json时返回）"
    },
    "output_path": {
      "type": "string",
      "description": "输出文件路径（output_format=path时返回）"
    }
  },
  "tags": ["subtitle", "whisper", "audio", "srt", "api", "字幕打轴", "打轴", "subtitle-timing"],
  "docker": {
    "image": "onebigmoon/subtitle-generator:latest",
    "ports": ["8000:8000"],
    "composeFile": "docker-compose.yml",
    "volumes": [
      "./input:/app/input",
      "./output:/app/output"
    ]
  }
}
